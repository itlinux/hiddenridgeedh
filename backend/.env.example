# MongoDB (using existing system instance — new dedicated database)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=hiddenridgeedh

# JWT
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@hiddenridgeedh.com
FROM_NAME=Hidden Ridge EDH

# App
APP_URL=https://hiddenridgeedh.com
ADMIN_EMAIL=remo@hiddenridgeedh.com
ENVIRONMENT=development

# File uploads (local path)
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
